# Census Bureau API key (free, 5-min signup at https://api.census.gov/data/key_signup.html)
# Optional - Census ACS tolerates unkeyed requests for low volume, but a key is recommended.
CENSUS_API_KEY=

# ACS 5-Year vintage (most recent published). Change to 2023 once released.
ACS_YEAR=2022

# Port
PORT=3000

# Frontend origin for CORS (comma-separated). Leave empty to allow all.
ALLOWED_ORIGINS=
