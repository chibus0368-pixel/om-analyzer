rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // ===== ARTICLES =====
    match /articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== DEALS =====
    match /deals/{dealId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== GLOSSARY =====
    match /glossary/{termId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== GUIDES =====
    match /guides/{guideId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== MARKET DATA SERIES =====
    match /series/{seriesId} {
      allow read: if true;
      allow write: if isAdmin();

      match /points/{pointId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ===== MARKET SNAPSHOT =====
    match /market_snapshot/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== MARKET DATA (latest rates, history) =====
    match /market_data/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== TICKER CONFIG =====
    match /ticker_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== SITE CONFIG =====
    match /site_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== CALCULATORS =====
    match /calculators/{calcId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== SUBSCRIBERS =====
    match /subscribers/{subscriberId} {
      allow read: if isAuthenticated() && request.auth.uid == subscriberId;
      allow create: if true;
      allow update: if isAdmin() ||
        (isAuthenticated() && request.auth.uid == subscriberId);
      allow delete: if isAdmin();
    }

    // ===== EMAIL CAMPAIGNS =====
    match /email_campaigns/{campaignId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ===== EMAIL SENDS / EVENTS =====
    match /email_sends/{sendId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /email_events/{eventId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ===== INGESTION LOGS =====
    match /ingestion_logs/{logId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== AI TOOLS =====
    match /ai_tools/{toolId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== AI WORKFLOWS =====
    match /ai_workflows/{workflowId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== ADMINS =====
    match /admins/{adminId} {
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      allow write: if false; // Managed via Admin SDK only
    }

    // ===== WORKSPACE COLLECTIONS =====
    // Simplified rules: authenticated users can read/write all workspace data.
    // Owner-level scoping is enforced at the application layer (API routes
    // filter by userId). Firestore rules just gate on auth presence so
    // client-side queries for extracted fields, scores, etc. don't fail.

    match /workspace_properties/{propertyId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_documents/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_projects/{projectId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_extracted_fields/{fieldId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_scores/{scoreId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_notes/{noteId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_outputs/{outputId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_tasks/{taskId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_activity_logs/{logId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_parser_runs/{runId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_property_snapshots/{snapshotId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_underwriting_models/{modelId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_underwriting_outputs/{outputId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_shared_views/{viewId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /workspace_workspaces/{wsId} {
      allow read, write: if isAuthenticated();
    }

    // The `workspaces` collection holds the per-workspace settings doc
    // (name, analysisType, underwritingDefaults baseline, etc.). Reads
    // happen client-side on every workspace switch; writes happen from
    // the Settings page and from the workspace rename flow.
    match /workspaces/{wsId} {
      allow read, write: if isAuthenticated();
    }

    match /workspace_members/{memberId} {
      allow read, write: if isAuthenticated();
    }

    // ===== USERS (for profile/billing data) =====
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
